# Example environment variables for local development and Vercel
# Copy this file to `.env.local` (do NOT commit secrets to git) and fill in the real values.

NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: other env vars you might need
# NEXT_PUBLIC_OTHER_API_KEY=

# Notes:
# - Do NOT commit real secrets to the repository.
# - On Vercel: go to Project Settings → Environment Variables and add these keys with their real values.
# - For local development: create a `.env.local` file at the project root and paste the real values there.
